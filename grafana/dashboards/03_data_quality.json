    },
    "description": "Data quality monitoring — missing PRO_NUMBER and other gaps",
    "editable": true,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "datasource": {
                "type": "postgres",
                "uid": "${DS_POSTGRESQL}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 30
                            },
                            {
                                "color": "red",
                                "value": 70
                            }
                        ]
                    },
                    "unit": "percent",
                    "min": 0,
                    "max": 100
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "showThresholdLabels": false,
                "showThresholdMarkers": true
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "${DS_POSTGRESQL}"
                    },
                    "format": "table",
                    "rawSql": "SELECT\n  ROUND(\n    100.0 * COUNT(*) FILTER (WHERE pro_number IS NULL OR pro_number = '')\n    / NULLIF(COUNT(*), 0),\n  2) AS value\nFROM shipments\nWHERE $__timeFilter(appointment_date)",
                    "refId": "A"
                }
            ],
            "title": "% Missing PRO_NUMBER",
            "type": "gauge"
        },
        {
            "datasource": {
                "type": "postgres",
                "uid": "${DS_POSTGRESQL}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 0
            },
            "id": 2,
            "options": {
                "colorMode": "background",
                "graphMode": "none",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "${DS_POSTGRESQL}"
                    },
                    "format": "table",
                    "rawSql": "SELECT COUNT(*) AS value FROM shipments\nWHERE $__timeFilter(appointment_date)\n  AND (pro_number IS NULL OR pro_number = '')",
                    "refId": "A"
                }
            ],
            "title": "Shipments Missing PRO_NUMBER",
            "type": "stat"
        },
        {
            "datasource": {
                "type": "postgres",
                "uid": "${DS_POSTGRESQL}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 0
