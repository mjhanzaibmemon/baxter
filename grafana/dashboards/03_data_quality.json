            "id": 3,
            "options": {
                "colorMode": "background",
                "graphMode": "none",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "${DS_POSTGRESQL}"
                    },
                    "format": "table",
                    "rawSql": "SELECT COUNT(*) AS value FROM shipments\nWHERE $__timeFilter(appointment_date)\n  AND pro_number IS NOT NULL AND pro_number != ''",
                    "refId": "A"
                }
            ],
            "title": "Shipments WITH PRO_NUMBER",
            "type": "stat"
        },
        {
            "datasource": {
                "type": "postgres",
                "uid": "${DS_POSTGRESQL}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 20,
                        "lineWidth": 2
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 10,
                "w": 24,
                "x": 0,
                "y": 8
            },
            "id": 4,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "${DS_POSTGRESQL}"
                    },
                    "format": "time_series",
                    "rawSql": "SELECT\n  date_trunc('hour', appointment_date) AS time,\n  COUNT(*) FILTER (WHERE pro_number IS NULL OR pro_number = '') AS missing_pro,\n  COUNT(*) FILTER (WHERE pro_number IS NOT NULL AND pro_number != '') AS has_pro\nFROM shipments\nWHERE $__timeFilter(appointment_date)\nGROUP BY 1\nORDER BY 1",
                    "refId": "A"
                }
            ],
            "title": "PRO_NUMBER Completeness Over Time",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "postgres",
                "uid": "${DS_POSTGRESQL}"
            },
            "fieldConfig": {
                "defaults": {},
                "overrides": []
            },
            "gridPos": {
                "h": 12,
                "w": 24,
                "x": 0,
                "y": 18
            },
            "id": 5,
            "options": {
                "footer": {
                    "show": false
                },
                "showHeader": true
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "${DS_POSTGRESQL}"
                    },
                    "format": "table",
                    "rawSql": "SELECT\n  appointment_date,\n  sscc18,\n  scac,\n  order_id,\n  shipment_id,\n  source_file,\n  ingested_at\nFROM shipments\nWHERE $__timeFilter(appointment_date)\n  AND (pro_number IS NULL OR pro_number = '')\nORDER BY appointment_date DESC\nLIMIT 500",
                    "refId": "A"
                }
            ],
            "title": "Records Missing PRO_NUMBER (Drilldown)",
            "type": "table"
        }
    ],
