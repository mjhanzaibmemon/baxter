            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "time_series",
                "rawSql": "WITH date_series AS (\n  SELECT d::date as day\n  FROM generate_series(\n    ($__timeFrom())::date - INTERVAL '6 days',\n    ($__timeTo())::date,\n    '1 day'::interval\n  ) d\n),\ndaily_claims AS (\n  SELECT\n    ds.day,\n    COALESCE(SUM(ABS(cd.claim_amount)), 0) as daily_total,\n    COUNT(cd.id) as claim_count\n  FROM date_series ds\n  LEFT JOIN claim_details cd ON cd.claim_date::date = ds.day\n    AND ('$__all' IN (${claim_type:singlequote}) OR cd.claim_type IN (${claim_type:singlequote}))\n    AND ('$__all' IN (${carrier:singlequote}) OR cd.carrier_bp IN (${carrier:singlequote}) OR cd.carrier_bp IS NULL)\n  GROUP BY ds.day\n)\nSELECT\n  day::timestamp as time,\n  daily_total as \"Claims $\",\n  AVG(daily_total) OVER (ORDER BY day ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) as \"7-Day Moving Avg\",\n  claim_count as \"Claim Count\"\nFROM daily_claims\nWHERE day >= ($__timeFrom())::date\nORDER BY day",
                "refId": "A"
            }],
            "title": "Claim Count vs Claims $",
            "type": "timeseries"
        },
