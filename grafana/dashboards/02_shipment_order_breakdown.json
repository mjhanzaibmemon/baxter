                "format": "time_series",
                "rawSql": "WITH date_series AS (\n  SELECT d::date as day\n  FROM generate_series(\n    ($__timeFrom())::date,\n    ($__timeTo())::date,\n    '1 day'::interval\n  ) d\n)\nSELECT\n  ds.day::timestamp as time,\n  COUNT(s.id) as \"Daily Barcode Scans\"\nFROM date_series ds\nLEFT JOIN shipments s ON s.appointment_date::date = ds.day\nGROUP BY ds.day\nORDER BY ds.day",
