                    "format": "table",
                    "rawSql": "SELECT TO_CHAR(COUNT(*), 'FM99,999') || ' / ' || COUNT(DISTINCT claim_date::date) || ' Days' as \"Claims / Days\" FROM claim_details WHERE claim_date < '2025-05-01' AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote})) AND ('$__all' IN (${carrier:singlequote}) OR carrier_bp IN (${carrier:singlequote}) OR carrier_bp IS NULL)",
