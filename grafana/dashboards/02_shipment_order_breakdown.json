                    "refId": "B"
                }
            ],
            "title": "After Validation Claims",
            "type": "stat"
        },
        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": { "custom": { "align": "auto", "filterable": true } },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "Validation Status" },
                        "properties": [
                            { "id": "custom.displayMode", "value": "color-text" },
                            { "id": "mappings", "value": [{ "options": { "Valid": { "color": "green", "index": 0, "text": "\u2714 Valid" } }, "type": "value" }] }
                        ]
                    },
                    { "matcher": { "id": "byName", "options": "Claim Date" }, "properties": [{ "id": "custom.width", "value": 140 }] },
                    { "matcher": { "id": "byName", "options": "Order ID" }, "properties": [{ "id": "custom.width", "value": 160 }] },
                    { "matcher": { "id": "byName", "options": "SSCC18" }, "properties": [{ "id": "custom.width", "value": 200 }] }
                ]
            },
            "gridPos": { "h": 14, "w": 12, "x": 0, "y": 32 },
            "id": 3,
            "options": {
                "footer": { "show": true, "countRows": true, "reducer": ["count"] },
                "showHeader": true,
                "sortBy": [{ "desc": true, "displayName": "Claim Date" }]
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "table",
                "rawSql": "SELECT\n  TO_CHAR(claim_date, 'Mon DD, YYYY') AS \"Claim Date\",\n  order_id AS \"Order ID\",\n  sscc18 AS \"SSCC18\",\n  CASE WHEN EXISTS (SELECT 1 FROM shipments s WHERE s.sscc18 = c.sscc18) THEN '\u2713 Valid' ELSE '\u2717 Not Scanned' END AS \"Validation Status\"\nFROM claim_details c\nWHERE $__timeFilter(claim_date)\n  AND ('${order_id:raw}' = '' OR order_id ILIKE '%${order_id:raw}%')\n  AND ('${sscc18:raw}' = '' OR sscc18 ILIKE '%${sscc18:raw}%')\n  AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote}))\n  AND ('$__all' IN (${carrier:singlequote}) OR carrier_bp IN (${carrier:singlequote}) OR carrier_bp IS NULL)\nORDER BY claim_date DESC\nLIMIT 500",
                "refId": "A"
            }],
            "title": "Customer Claim Log",
            "type": "table"
        },
