                    { "matcher": { "id": "byName", "options": "Timestamp" }, "properties": [{ "id": "custom.width", "value": 180 }] },
                    { "matcher": { "id": "byName", "options": "Order ID" }, "properties": [{ "id": "custom.width", "value": 160 }] },
                    { "matcher": { "id": "byName", "options": "SSCC18" }, "properties": [{ "id": "custom.width", "value": 200 }] }
                ]
            },
            "gridPos": { "h": 14, "w": 12, "x": 12, "y": 32 },
            "id": 4,
            "options": {
                "footer": { "show": true, "countRows": true, "reducer": ["count"] },
                "showHeader": true,
                "sortBy": [{ "desc": true, "displayName": "Timestamp" }]
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "table",
                "rawSql": "SELECT\n  TO_CHAR(appointment_date, 'Mon DD, YYYY HH12:MI') AS \"Timestamp\",\n  order_id AS \"Order ID\",\n  sscc18 AS \"SSCC18\",\n  CASE WHEN pro_number IS NOT NULL AND pro_number != '' THEN '\u2713 Valid' ELSE '\u2717 Missing PRO' END AS \"Validation Status\"\nFROM shipments\nWHERE $__timeFilter(appointment_date)\n  AND ('${order_id:raw}' = '' OR order_id ILIKE '%${order_id:raw}%')\n  AND ('${sscc18:raw}' = '' OR sscc18 ILIKE '%${sscc18:raw}%')\nORDER BY appointment_date DESC\nLIMIT 500",
                "refId": "A"
            }],
            "title": "Scanned Barcode Log",
            "type": "table"
        }
