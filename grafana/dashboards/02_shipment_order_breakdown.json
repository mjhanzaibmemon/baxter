                            { "id": "custom.lineWidth", "value": 2 },
                            { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
                            { "id": "custom.fillOpacity", "value": 0 }
                        ]
                    }
                ]
            },
            "gridPos": { "h": 13, "w": 14, "x": 0, "y": 19 },
            "id": 20,
            "options": {
                "legend": { "displayMode": "list", "placement": "bottom" },
                "tooltip": { "mode": "multi" }
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "time_series",
                "rawSql": "WITH date_series AS (\n  SELECT d::date as day\n  FROM generate_series(\n    ($__timeFrom())::date - INTERVAL '6 days',\n    ($__timeTo())::date,\n    '1 day'::interval\n  ) d\n),\ndaily AS (\n  SELECT\n    ds.day,\n    COUNT(DISTINCT s.id) as scans,\n    COUNT(DISTINCT cd.id) as claims\n  FROM date_series ds\n  LEFT JOIN shipments s ON s.appointment_date::date = ds.day\n  LEFT JOIN claim_details cd ON cd.claim_date::date = ds.day\n    AND ('$__all' IN (${claim_type:singlequote}) OR cd.claim_type IN (${claim_type:singlequote}))\n    AND ('$__all' IN (${carrier:singlequote}) OR cd.carrier_bp IN (${carrier:singlequote}) OR cd.carrier_bp IS NULL)\n  GROUP BY ds.day\n),\nratio AS (\n  SELECT day,\n    CASE WHEN scans > 0 THEN ROUND(claims::numeric / scans * 1000, 1) ELSE 0 END as ratio_val\n  FROM daily\n)\nSELECT\n  day::timestamp as time,\n  ratio_val as \"Claims per 1,000 Scans\",\n  AVG(ratio_val) OVER (ORDER BY day ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) as \"7-Day Avg Ratio\"\nFROM ratio\nWHERE day >= ($__timeFrom())::date\nORDER BY day",
                "refId": "A"
            }],
            "title": "Claims per 1,000 Barcode Scans",
            "type": "timeseries"
