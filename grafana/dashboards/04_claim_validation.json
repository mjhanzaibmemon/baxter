                "format": "table",
                "rawSql": "SELECT COUNT(*) AS \"Claims Submitted\" FROM claim_details WHERE $__timeFilter(claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote})) AND business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK')",
                "refId": "A"
            }],
            "title": "",
            "transparent": false,
            "type": "stat"
        },

        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "thresholds": { "mode": "absolute", "steps": [{ "color": "#56A64B", "value": null }] },
                    "unit": "none", "decimals": 0, "noValue": "0"
                },
                "overrides": []
            },
            "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
            "id": 3,
            "options": {
                "colorMode": "value",
                "graphMode": "none",
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "textMode": "value_and_name",
                "justifyMode": "center"
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "table",
                "rawSql": "SELECT COUNT(*) AS \"Verified Shortages\" FROM claim_details c WHERE $__timeFilter(c.claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR c.claim_type IN (${claim_type:singlequote})) AND c.business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK') AND EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id)))",
                "refId": "A"
            }],
            "title": "",
            "transparent": false,
            "type": "stat"
        },

        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "thresholds": { "mode": "absolute", "steps": [{ "color": "#F2495C", "value": null }] },
                    "unit": "none", "decimals": 0, "noValue": "0"
                },
                "overrides": []
            },
            "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
            "id": 4,
            "options": {
                "colorMode": "value",
                "graphMode": "none",
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "textMode": "value_and_name",
                "justifyMode": "center"
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "table",
                "rawSql": "SELECT COUNT(*) AS \"Invalid Claims\" FROM claim_details c WHERE $__timeFilter(c.claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR c.claim_type IN (${claim_type:singlequote})) AND c.business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK') AND NOT EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id)))",
                "refId": "A"
            }],
            "title": "",
            "transparent": false,
            "type": "stat"
        },

        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": {
                        "fillOpacity": 5,
                        "lineWidth": 2,
                        "spanNulls": true,
                        "drawStyle": "line",
                        "showPoints": "always",
                        "pointSize": 5,
                        "lineInterpolation": "smooth"
                    },
                    "unit": "percentunit",
                    "decimals": 1,
                    "min": 0,
                    "max": 1.0
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "Claim Rate" },
                        "properties": [
                            { "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }
                        ]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Verified Shortage Rate" },
                        "properties": [
                            { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
                        ]
                    }
                ]
            },
            "gridPos": { "h": 7, "w": 24, "x": 0, "y": 4 },
            "id": 5,
            "options": {
                "legend": { "displayMode": "list", "placement": "right" },
                "tooltip": { "mode": "multi" }
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "time_series",
                "rawSql": "WITH cm AS (\n  SELECT date_trunc('month', claim_date) AS mo,\n    COUNT(*) AS sc,\n    COUNT(*) FILTER(WHERE EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id)))) AS v\n  FROM claim_details c\n  WHERE $__timeFilter(claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote})) AND business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK')\n  GROUP BY 1\n),\nsm AS (\n  SELECT date_trunc('month', appointment_date) AS mo, COUNT(DISTINCT order_id) AS o\n  FROM shipments WHERE $__timeFilter(appointment_date) AND ('$__all' IN (${carrier:singlequote}) OR scac IN (${carrier:singlequote})) GROUP BY 1\n)\nSELECT COALESCE(cm.mo, sm.mo)::timestamp AS time,\n  CASE WHEN COALESCE(sm.o,0)>0 THEN COALESCE(cm.sc,0)::numeric/sm.o ELSE 0 END AS \"Claim Rate\",\n  CASE WHEN COALESCE(sm.o,0)>0 THEN COALESCE(cm.v,0)::numeric/sm.o ELSE 0 END AS \"Verified Shortage Rate\"\nFROM cm FULL JOIN sm ON sm.mo=cm.mo\nORDER BY time",
                "refId": "A"
            }],
            "title": "Claim & Shortage Rate Over Time",
            "type": "timeseries"
        },

        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": {
                        "fillOpacity": 80,
                        "lineWidth": 0,
                        "stacking": { "mode": "normal" }
                    },
                    "unit": "short"
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "Verified" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Invalid" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "#3274D9", "mode": "fixed" } }]
                    }
                ]
            },
            "gridPos": { "h": 8, "w": 7, "x": 0, "y": 11 },
            "id": 6,
            "options": {
                "legend": { "displayMode": "list", "placement": "bottom" },
                "tooltip": { "mode": "multi" },
                "orientation": "horizontal",
                "barWidth": 0.5,
                "groupWidth": 0.8,
                "showValue": "never",
                "stacking": "normal"
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "table",
                "rawSql": "SELECT COALESCE(c.ship_to_name, c.address_name, 'Unknown') AS \"Customer\",\n  COUNT(*) FILTER(WHERE EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id)))) AS \"Verified\",\n  COUNT(*) FILTER(WHERE NOT EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id)))) AS \"Invalid\"\nFROM claim_details c\nWHERE $__timeFilter(claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote})) AND c.business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK')\nGROUP BY COALESCE(c.ship_to_name, c.address_name, 'Unknown')\nORDER BY COUNT(*) DESC\nLIMIT 5",
                "refId": "A"
            }],
            "title": "Claims by Customer",
            "type": "barchart"
        },

        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "align": "auto",
                        "filterable": true,
                        "inspect": true,
                        "cellOptions": { "type": "auto" }
                    },
                    "color": { "mode": "fixed", "fixedColor": "transparent" }
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "Valid Claim" },
                        "properties": [
                            {
                                "id": "color",
                                "value": { "mode": "thresholds" }
                            },
                            {
                                "id": "thresholds",
                                "value": {
                                    "mode": "absolute",
                                    "steps": [
                                        { "color": "rgba(153, 30, 30, 0.35)", "value": null },
                                        { "color": "rgba(55, 135, 45, 0.30)", "value": 1 }
                                    ]
                                }
                            },
                            {
                                "id": "custom.cellOptions",
                                "value": {
                                    "type": "color-background",
                                    "applyToRow": true
                                }
                            },
                            {
                                "id": "mappings",
                                "value": [
                                    {
                                        "type": "value",
                                        "options": {
                                            "0": { "index": 0, "text": "\u2718 No" },
                                            "1": { "index": 1, "text": "\u2714 Yes" }
                                        }
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            "gridPos": { "h": 8, "w": 17, "x": 7, "y": 11 },
            "id": 7,
            "options": {
                "footer": { "show": true, "countRows": true, "reducer": ["count"] },
                "showHeader": true,
                "sortBy": [],
                "cellHeight": "sm"
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "table",
                "rawSql": "SELECT\n  c.order_id AS \"Order\",\n  COALESCE(c.ship_to_name, c.address_name, 'Unknown') AS \"Ship To\",\n  COALESCE(c.contact_name, '') AS \"Contact Name\",\n  COALESCE(c.item_number, '') AS \"Item Number\",\n  c.quantity AS \"Qty Ordered\",\n  COALESCE(c.unit_of_measure, '') AS \"UM\",\n  c.sscc18 AS \"SSCC18\",\n  CASE\n    WHEN EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id))) THEN 1\n    ELSE 0\n  END AS \"Valid Claim\",\n  COALESCE((SELECT s.order_status FROM shipments s WHERE s.order_id = c.order_id AND s.order_status IS NOT NULL LIMIT 1), '-') AS \"Order Status\",\n  CASE\n    WHEN c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND EXISTS(SELECT 1 FROM shipments s WHERE s.sscc18=c.sscc18) THEN 'Matched by SSCC18'\n    WHEN (c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND EXISTS(SELECT 1 FROM shipments s WHERE s.order_id=c.order_id) THEN 'Matched by Order ID'\n    ELSE 'No Matching Shipment'\n  END AS \"Notes\"\nFROM claim_details c\nWHERE $__timeFilter(c.claim_date)\n  AND ('$__all' IN (${claim_type:singlequote}) OR c.claim_type IN (${claim_type:singlequote}))\n  AND c.business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK')\n  AND ('${order_id:raw}'='' OR c.order_id ILIKE '%${order_id:raw}%')\nORDER BY c.claim_date DESC\nLIMIT 500",
                "refId": "A"
            }],
            "title": "Claim Validation Details",
            "type": "table"
        },

        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": {
                        "fillOpacity": 80,
                        "lineWidth": 0,
                        "stacking": { "mode": "none" }
                    },
                    "unit": "short"
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "IV Bag 1000ml" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "#3274D9", "mode": "fixed" } }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Syringe 5ml" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "#8AB8FF", "mode": "fixed" } }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Saline 500ml" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
                    }
                ]
            },
            "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
            "id": 8,
            "options": {
                "legend": { "displayMode": "list", "placement": "bottom" },
                "tooltip": { "mode": "multi" },
                "barWidth": 0.6,
                "groupWidth": 0.7,
                "orientation": "horizontal",
                "showValue": "auto",
                "stacking": "none"
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "table",
                "rawSql": "SELECT COALESCE(c.item_number, 'Unknown') AS \"Item Number\",\n  COUNT(*) AS \"Claims\",\n  COUNT(*) FILTER(WHERE EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id)))) AS \"Verified Claims\"\nFROM claim_details c\nWHERE $__timeFilter(claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote}))\nAND c.business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK')\nAND c.item_number ~ '^[A-Za-z]'\nGROUP BY COALESCE(c.item_number, 'Unknown')\nORDER BY COUNT(*) DESC\nLIMIT 10",
                "refId": "A"
            }],
            "title": "Claims by Item",
            "type": "barchart"
        },

        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": {
                        "fillOpacity": 80,
                        "lineWidth": 0
                    },
                    "unit": "short"
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "IV Bag 1000ml" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "#3274D9", "mode": "fixed" } }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Syringe 5ml" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "#8AB8FF", "mode": "fixed" } }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Saline 500ml" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
                    }
                ]
            },
            "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
            "id": 9,
            "options": {
                "legend": { "displayMode": "list", "placement": "right" },
                "tooltip": { "mode": "single" },
                "orientation": "horizontal",
                "barWidth": 0.5,
                "groupWidth": 0.8,
                "showValue": "never",
                "stacking": "none"
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "table",
                "rawSql": "SELECT COALESCE(item_number, 'Unknown') AS \"Item Number\",\n  ROUND(SUM(ABS(claim_amount))::numeric, 2) AS \"Claim $\"\nFROM claim_details\nWHERE $__timeFilter(claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote}))\nAND business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK')\nAND item_number ~ '^[A-Za-z]'\nGROUP BY COALESCE(item_number, 'Unknown')\nORDER BY SUM(ABS(claim_amount)) DESC\nLIMIT 10",
                "refId": "A"
            }],
            "title": "Claim $ by Item",
            "type": "barchart"
        },

        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": {
                    "custom": { "align": "auto", "filterable": true },
                    "color": { "mode": "thresholds" }
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "Branch" },
                        "properties": [{ "id": "custom.width", "value": 140 }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Total Shortages" },
                        "properties": [{ "id": "custom.width", "value": 105 }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Verified Shortages" },
                        "properties": [{ "id": "custom.width", "value": 120 }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Invalid Claims" },
                        "properties": [{ "id": "custom.width", "value": 95 }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Verified %" },
                        "properties": [
                            { "id": "unit", "value": "percentunit" },
                            { "id": "decimals", "value": 1 },
                            { "id": "custom.width", "value": 80 }
                        ]
                    }
                ]
            },
            "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
            "id": 10,
            "options": {
                "footer": { "show": false },
                "showHeader": true,
                "sortBy": [{ "desc": true, "displayName": "Invalid Claims" }],
                "cellHeight": "sm"
            },
            "targets": [{
                "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
                "format": "table",
                "rawSql": "SELECT\n  COALESCE(c.branch, 'Unknown') AS \"Branch\",\n  COUNT(*) AS \"Total Shortages\",\n  COUNT(*) FILTER(WHERE EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id)))) AS \"Verified Shortages\",\n  COUNT(*) FILTER(WHERE NOT EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id)))) AS \"Invalid Claims\",\n  CASE WHEN COUNT(*)>0\n    THEN COUNT(*) FILTER(WHERE EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR ((c.sscc18 IS NULL OR c.sscc18='') AND c.order_id IS NOT NULL AND c.order_id <> '' AND s.order_id=c.order_id))))::numeric / COUNT(*)\n    ELSE 0\n  END AS \"Verified %\"\nFROM claim_details c\nWHERE $__timeFilter(c.claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR c.claim_type IN (${claim_type:singlequote})) AND c.business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK')\nGROUP BY COALESCE(c.branch, 'Unknown')\nORDER BY \"Invalid Claims\" DESC, \"Total Shortages\" DESC",
                "refId": "A"
            }],
            "title": "Shortages by Branch",
            "type": "table"
        },

        {
            "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": {
                        "fillOpacity": 70,
                        "lineWidth": 0,
                        "drawStyle": "bars",
                        "showPoints": "never",
                        "stacking": { "mode": "none" }
                    },
                    "unit": "short"
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "Orders Shipped" },
                        "properties": [
                            { "id": "color", "value": { "fixedColor": "#3274D9", "mode": "fixed" } },
                            { "id": "custom.axisPlacement", "value": "left" }
                        ]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Claims Submitted" },
