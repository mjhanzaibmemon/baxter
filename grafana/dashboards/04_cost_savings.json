            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "${DS_POSTGRESQL}"
                    },
                    "format": "table",
                    "rawSql": "SELECT\n  carrier_bp,\n  claim_type,\n  ABS(SUM(claim_amount))                                          AS total_credit,\n  COUNT(*)                                                       AS claim_count,\n  ROUND(ABS(SUM(claim_amount)) / NULLIF(COUNT(*), 0), 2)        AS avg_per_claim\nFROM claim_details\nWHERE 1=1\n  AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote}))\n  AND ('$__all' IN (${carrier:singlequote}) OR carrier_bp IN (${carrier:singlequote}))\n  AND ABS(claim_amount) >= ${min_credit}\nGROUP BY carrier_bp, claim_type\nORDER BY total_credit DESC",
                    "refId": "A"
                }
