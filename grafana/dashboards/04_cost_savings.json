                    "datasource": {
                        "type": "postgres",
                        "uid": "${DS_POSTGRESQL}"
                    },
                    "format": "table",
                    "rawSql": "SELECT\n  ROUND(\n    100.0 * (before_avg - after_avg) / NULLIF(before_avg, 0)\n  , 1) AS value\nFROM (\n  SELECT\n    AVG(total_amount) FILTER (WHERE claim_date < '2025-03-01') AS before_avg,\n    AVG(total_amount) FILTER (WHERE claim_date >= '2025-03-01') AS after_avg\n  FROM claim_daily_history\n) sub",
                    "refId": "A"
                }
            ],
            "title": "Cost Reduction After Scanning",
            "type": "stat"
        },
