                    "format": "table",
                    "rawSql": "SELECT\n  TO_CHAR(claim_date, 'Mon DD, YYYY') AS \"Claim Date\",\n  order_id     AS \"Order ID\",\n  sscc18       AS \"SSCC18\",\n  claim_amount AS \"Claim Amount\",\n  claim_type   AS \"Claim Type\",\n  carrier_bp   AS \"Carrier\"\nFROM claim_details\nWHERE $__timeFilter(claim_date)\n  AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote}))\n  AND ('$__all' IN (${carrier:singlequote}) OR carrier_bp IN (${carrier:singlequote}))\n  AND ABS(claim_amount) >= ${min_credit}\nORDER BY claim_date DESC\nLIMIT 500",
                    "refId": "A"
