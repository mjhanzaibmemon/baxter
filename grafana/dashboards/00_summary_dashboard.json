                        "uid": "${DS_POSTGRESQL}"
                    },
                    "format": "table",
                    "rawSql": "SELECT COALESCE(c.ship_to_name, c.address_name, 'Unknown') AS \"Customer\",\n  COUNT(*) FILTER(WHERE EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR (c.order_id IS NOT NULL AND c.order_id <> '' AND ((LENGTH(c.order_id) = 7 AND RIGHT(s.order_id, 7) = c.order_id) OR (LENGTH(c.order_id) = 8 AND RIGHT(s.order_id, 8) = c.order_id)))))) AS \"Verified\",\n  COUNT(*) FILTER(WHERE NOT EXISTS(SELECT 1 FROM shipments s WHERE ('$__all' IN (${carrier:singlequote}) OR s.scac IN (${carrier:singlequote})) AND ((c.sscc18 IS NOT NULL AND c.sscc18 <> '' AND s.sscc18=c.sscc18) OR (c.order_id IS NOT NULL AND c.order_id <> '' AND ((LENGTH(c.order_id) = 7 AND RIGHT(s.order_id, 7) = c.order_id) OR (LENGTH(c.order_id) = 8 AND RIGHT(s.order_id, 8) = c.order_id)))))) AS \"Invalid\"\nFROM claim_details c\nWHERE $__timeFilter(claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote})) AND c.business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK')\nGROUP BY COALESCE(c.ship_to_name, c.address_name, 'Unknown')\nORDER BY COUNT(*) DESC\nLIMIT 7",
                    "refId": "A"
                }
            ],
            "title": "Verified vs Invalid Claims by Customer",
