            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "${DS_POSTGRESQL}"
                    },
                    "format": "time_series",
                    "rawSql": "WITH cw AS (\n  SELECT date_trunc('week', claim_date) AS d, COUNT(*) AS c\n  FROM claim_details\n  WHERE $__timeFilter(claim_date) AND ('$__all' IN (${claim_type:singlequote}) OR claim_type IN (${claim_type:singlequote})) AND business_unit_code IN ('1MF','1MY','1MQ','1MS','1MK')\n  GROUP BY 1\n),\nsw AS (\n  SELECT date_trunc('week', appointment_date) AS d, COUNT(DISTINCT order_id) AS o\n  FROM shipments\n  WHERE $__timeFilter(appointment_date) AND ('$__all' IN (${carrier:singlequote}) OR scac IN (${carrier:singlequote}))\n  GROUP BY 1\n)\nSELECT COALESCE(cw.d, sw.d)::timestamp AS time,\n  COALESCE(sw.o, 0) AS \"Orders Shipped\",\n  COALESCE(cw.c, 0) AS \"Claims Submitted\"\nFROM cw FULL JOIN sw ON sw.d=cw.d\nORDER BY time",
                    "refId": "A"
                }
            ],
            "title": "Orders Shipped and Claims Submitted Over Time",
            "type": "timeseries"
