# ============================================================
# Baxter Demo Pipeline - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=baxter_demo
POSTGRES_USER=baxter
POSTGRES_PASSWORD=baxter_secret_123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Microsoft Graph API (Real Mode) ---
# Leave blank for DEMO_MODE
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
MAILBOX_EMAIL=

# --- Demo Mode ---
# Set to "true" to skip Graph API and use local Excel files instead
DEMO_MODE=true
DEMO_EXCEL_DIR=/app/sample_data

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# --- Ingestor Schedule ---
# How often to poll for new emails (in minutes)
POLL_INTERVAL_MINUTES=30
